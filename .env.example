# ============================================================
# InfluencerPortal E2E QA — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# GitHub Actions uses repository Secrets instead of this file.
# ============================================================

# ── Target App URL ─────────────────────────────────────────
# Local:   http://localhost:3000
# Staging: https://staging.influencerportal.com
# Prod:    https://influencerportal.com
BASE_URL=https://staging.influencerportal.com

# ── Browser ────────────────────────────────────────────────
# Options: chromium | firefox | webkit
BROWSER=chromium

# ── Display Mode ───────────────────────────────────────────
# true  = headless (CI default)
# false = shows browser window (use for local debugging)
HEADLESS=true

# ── Slow Motion ─────────────────────────────────────────────
# Milliseconds between browser interactions (0 = max speed)
# Set to 500 for demo, 0 for CI
SLOW_MO=0

# ── CI Mode ────────────────────────────────────────────────
# true forces headless and enables retry/parallel settings
CI=false

# ── QA Test Credentials ────────────────────────────────────
# GitHub Actions: set as Repository Secrets (Settings → Secrets & Variables → Actions)
# Secret name:         QA_USER_EMAIL / QA_USER_PASSWORD
# Secret name:         QA_BRAND_EMAIL / QA_BRAND_PASSWORD
# Secret name:         QA_ADMIN_EMAIL / QA_ADMIN_PASSWORD
QA_USER_EMAIL=qa_influencer@influencerportal.com
QA_USER_PASSWORD=SecurePassword123!

QA_BRAND_EMAIL=qa_brand@influencerportal.com
QA_BRAND_PASSWORD=SecurePassword123!

QA_ADMIN_EMAIL=qa_admin@influencerportal.com
QA_ADMIN_PASSWORD=SecurePassword123!

# ── Tag Filtering ──────────────────────────────────────────
# Filters which Cucumber scenarios to run.
# Leave empty to run ALL tests.
# Examples: @smoke | @regression | @smoke and not @wip
TAGS=@smoke

# ── Slack Notifications (optional) ─────────────────────────
# GitHub Actions: set as Repository Secret → SLACK_WEBHOOK_URL
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
