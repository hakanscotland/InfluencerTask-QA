# Playwright Cucumber E2E QA Test Environment Variables

# The target URL under test (Staging, Pre-production, or Production)
BASE_URL=https://staging.influencerportal.com

# Headless mode toggle (true = background run, false = open browser UI)
HEADLESS=true

# Delay in milliseconds between browser interactions (useful for demo/debugging)
SLOW_MO=0

# QA Test Credentials (if needed for steps)
QA_USER_EMAIL=qa_influencer@influencerportal.com
QA_USER_PASSWORD=SecurePassword123!
QA_BRAND_EMAIL=qa_brand@influencerportal.com
QA_BRAND_PASSWORD=SecurePassword123!
